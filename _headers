# Cloudflare Pages — security + caching headers

# Security headers on every route
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# CSS/JS use plain (non-fingerprinted) filenames like main.css, so they must NOT be
# immutable — otherwise edits never reach returning visitors. Revalidate every load
# (cheap 304s) so deploys ship immediately.
/css/*
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Images are safe to cache forever — change one by giving it a new filename.
/img/*
  Cache-Control: public, max-age=31536000, immutable

# HTML should always revalidate so content updates ship immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate
