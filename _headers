# Cloudflare Pages — security + caching headers

# Security headers on every route
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# CSS/JS use plain (non-fingerprinted) filenames like main.css, so they must NOT be
# immutable — otherwise edits never reach returning visitors. Revalidate every load
# (cheap 304s) so deploys ship immediately.
/css/*
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Images are swapped in-place under the same filenames during the build-out, so they
# must revalidate too — otherwise replacing e.g. portfolio/img1.jpg keeps showing the
# old one. Once the site stabilizes, switch back to long/immutable caching AND give any
# changed image a new filename.
/img/*
  Cache-Control: public, max-age=0, must-revalidate

# HTML should always revalidate so content updates ship immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# XML files (sitemap, etc.) must be publicly accessible for Google Search Console
/*.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=0, must-revalidate
