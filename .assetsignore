# Files/folders excluded from Cloudflare static-assets (upload + dev watch).
# Stops the `wrangler dev` reload loop caused by watching its own temp dir,
# and keeps dev/config files out of the deployed site.

.wrangler
.git
.github
.claude
node_modules

# Worker source + style source (not static assets)
worker
scss

# Dev/config/secret files
.assetsignore
.gitignore
.dev.vars
.dev.vars.example
wrangler.jsonc
package.json
package-lock.json
CLAUDE.md

# OS / editor junk
__MACOSX
.DS_Store
**/.DS_Store
*.psd
